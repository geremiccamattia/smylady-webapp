{
  "redirects": [
    {
      "source": "/blog/:path*",
      "destination": "https://blog.shareyourparty.de/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "https://blog.shareyourparty.de/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}